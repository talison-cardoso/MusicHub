        <label for="title">Título da Música</label>
        <input
          type="text"
          id="title"
          name="title"
          placeholder="Ex: Minha Composição #1"
          required
        />
      </div>

      <div class="file-upload-wrapper">
        <label for="music-file" class="drop-zone" id="drop-zone">
          <svg
            xmlns="http://www.w3.org/2000/svg"
