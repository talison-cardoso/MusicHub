<script>
  import { toast } from '@/utils/toast';

  document.addEventListener('astro:page-load', () => {
    const modal = document.getElementById('music-modal') as HTMLDialogElement;
    const form = document.getElementById('upload-form') as HTMLFormElement;
    const fileInput = document.getElementById('music-file') as HTMLInputElement;
    const dropZone = document.getElementById('drop-zone');
    const fileNameDisplay = document.getElementById('file-name-display');
    const submitBtn = document.getElementById(
      'submit-upload-btn',
    ) as HTMLButtonElement;
    const closeBtn = document.getElementById('close-modal-btn');

    closeBtn?.addEventListener('click', () => {
      resetForm();
      modal.close();
    });

    // Drag and Drop Logic
    dropZone?.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });

    dropZone?.addEventListener('dragleave', () =>
      dropZone.classList.remove('drag-over'),
    );

    dropZone?.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      if (e.dataTransfer?.files.length) {
        fileInput.files = e.dataTransfer.files;
        updateUI(e.dataTransfer.files[0].name);
      }
    });

    fileInput?.addEventListener('change', () => {
      if (fileInput.files?.length) updateUI(fileInput.files[0].name);
    });

    function updateUI(name: string) {
      if (fileNameDisplay) fileNameDisplay.textContent = name;
      dropZone?.classList.add('has-file');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const file = formData.get('file') as File;
      const title = formData.get('title') as string;

      submitBtn.disabled = true;
      submitBtn.innerText = 'Enviando...';

      try {
        const signRes = await fetch('/api/admin/get-upload-url', {
          method: 'POST',
          body: JSON.stringify({ fileName: file.name, fileType: file.type }),
          headers: { 'Content-Type': 'application/json' },
        });

        if (!signRes.ok) throw new Error('Erro ao obter URL assinada');
        const { signedUrl, key } = await signRes.json();

        const uploadRes = await fetch(signedUrl, {
          method: 'PUT',
          body: file,
          headers: { 'Content-Type': file.type },
        });

        if (!uploadRes.ok) throw new Error('Erro no upload R2');

        const saveRes = await fetch('/api/admin/save-metadata', {
          method: 'POST',
          body: JSON.stringify({ title, musicKey: key }),
          headers: { 'Content-Type': 'application/json' },
        });

        if (saveRes.ok) {
          toast('Música adicionada com sucesso!', 'success');
          resetForm();
          modal.close();
          // TODO: quem sabe implementar um nanoStores para evitar o reload e perder a mensagem do toast...
          // Opcional: window.location.reload() ou disparar evento para atualizar a lista
          window.location.reload();
        }
      } catch (err) {
        console.error({ err });
        toast('Falha ao enviar música.', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerText = 'Enviar Música';
      }
    });

    function resetForm() {
      form.reset();
      fileNameDisplay!.textContent = 'Nenhum arquivo selecionado';
      dropZone!.classList.remove('has-file');
    }
  });
</script>
