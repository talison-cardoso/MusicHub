              y1="3"
              x2="12"
              y2="15"></line></svg
          >
          <div class="text-content">
            <span class="main-text">Clique para selecionar</span>
            <span class="sub-text">ou arraste o áudio aqui</span>
          </div>
          <span id="file-name-display" class="file-name-display"
            >Nenhum arquivo selecionado</span
          >
        </label>
        <input
          type="file"
          id="music-file"
          name="file"
          accept="audio/*"
          required
        />
      </div>

      <button type="submit" class="submit-btn" id="submit-upload-btn">
        <span>Enviar Música</span>
      </button>
    </form>
  </div>
</dialog>

