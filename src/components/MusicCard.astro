---
interface Props {
  id: string;
  title: string;
  fileKey: string;
  createdAt: Date;
  isAdmin?: boolean;
}

const { id, title, fileKey, createdAt, isAdmin = false } = Astro.props;

const BUCKET_PUBLIC_URL = 'https://pub-ad93f4e240374ab3ba91c0fd97c6c48e.r2.dev';
const musicFullUrl = `${BUCKET_PUBLIC_URL}/${fileKey}`;

const dateFormatted = new Intl.DateTimeFormat('pt-BR').format(
  new Date(createdAt),
);
---

<div class="card" data-id={id} data-key={fileKey} data-title={title}>
  <div class="info">
    <h3 class="song-title">{title}</h3>
    <span class="date">Adicionada em: {dateFormatted}</span>
  </div>
  <div class="actions">
    <button
      class="download-btn"
      data-url={musicFullUrl}
      data-filename={fileKey}
    >
      Download
    </button>
    {
      isAdmin && (
        <>
          <button class="edit-btn" title="Editar título">
            Editar
          </button>
          <button class="delete-btn" title="Excluir música">
            Excluir
          </button>
        </>
      )
    }
  </div>
</div>

<style>
  .card {
    display: flex;
    flex-direction: column;
  }

  .info {
    height: 100%;
    h3 {
      margin: 0;
      font-size: 1.125rem;
    }
    span {
      color: gray;
      font-size: 0.875rem;
    }
  }
  .actions {
    display: flex;
    gap: 0.75rem;
    margin-left: auto;
    button {
      font-size: 1rem;
      margin-top: 0.875rem;
      width: max-content;
      &:disabled {
        opacity: 50%;
      }
    }
    .download-btn {
      color: var(--primary-color);
      border: 1px solid #11f8;
      &:hover {
        background-color: #11f1;
      }
    }
    .delete-btn {
      color: #ef4444;
      border: 1px solid #ef444480;
      &:hover {
        background-color: #ef444411;
      }
    }
    .edit-btn {
      color: #f59e0b;
      border: 1px solid #f59e0b80;
      &:hover {
        background-color: #f59e0b11;
      }
    }
  }
</style>

<script>
  async function downloadAudio(
    url: string,
    filename: string,
    btn: HTMLButtonElement,
  ) {
    const originalText = btn.innerText;

    try {
      btn.disabled = true;
      btn.innerText = 'Baixando...';

      const response = await fetch(url);
      if (!response.ok) throw new Error(`Status: ${response.status}`);

      const blob = await response.blob();
      const objectUrl = URL.createObjectURL(blob);

      const link = document.createElement('a');
      link.href = objectUrl;
      link.download = filename;

      document.body.appendChild(link);
      link.click();

      document.body.removeChild(link);
      URL.revokeObjectURL(objectUrl);
    } catch (err) {
      alert('Falha no download.');
    } finally {
      btn.disabled = false;
      btn.innerText = originalText;
    }
  }

  function initMusicActions() {
    document.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('button');
      if (!btn) return;

      const card = btn.closest('.card') as HTMLElement;
      if (!card) return;

      const id = card.dataset.id;
      const musicKey = card.dataset.key;
      const currentTitle = card.dataset.title;

      // Ação: Download
      if (btn.classList.contains('download-btn')) {
        const url = btn.dataset.url;
        const filename = btn.dataset.filename || 'audio.mp3';
        if (url) downloadAudio(url, filename, btn);
      }

      // Ação: Delete
      if (btn.classList.contains('delete-btn') && id && musicKey) {
        if (!confirm(`Excluir "${currentTitle}"?`)) return;
        btn.disabled = true;
        const res = await fetch('/api/admin/delete-music', {
          method: 'POST',
          body: JSON.stringify({ id, musicKey }),
          headers: { 'Content-Type': 'application/json' },
        });
        if (res.ok) card.remove();
        else {
          alert('Erro ao deletar.');
          btn.disabled = false;
        }
      }

      // Ação: Edit
      if (btn.classList.contains('edit-btn') && id) {
        const newTitle = prompt('Novo título:', currentTitle || '');
        if (!newTitle || newTitle === currentTitle) return;

        const res = await fetch('/api/admin/edit-music', {
          method: 'POST',
          body: JSON.stringify({ id, title: newTitle }),
          headers: { 'Content-Type': 'application/json' },
        });

        if (res.ok) {
          const titleEl = card.querySelector('.song-title');
          if (titleEl) titleEl.textContent = newTitle;
          card.dataset.title = newTitle;
        }
      }
    });
  }

  document.addEventListener('astro:page-load', initMusicActions);
</script>
